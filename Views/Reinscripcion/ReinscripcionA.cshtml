@{
    ViewData["Title"] = "Reinscripcion";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <style>
        body {
            font-family: "Segoe UI", Tahoma, sans-serif;
            background: #ffffff;
            margin: 0;
            padding: 40px;
        }

        h2 {
            text-align: left;
            margin-bottom: 25px;
            font-size: 26px;
        }

        .contenedor {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            width: 100%;
            max-width: 900px;
            margin: 0 auto;
            gap: 35px;
        }

        .card {
            width: 100%;
            border-radius: 8px;
            padding: 22px 24px;
        }

            .card.blanco {
                background: #ffff;
            }

            .card.naranja {
                background: #ffbd66;
                border: 2px solid #000;
                box-sizing: border-box;
            }

        .titulo {
            text-align: left;
            font-size: 25px;
            font-weight: bold;
            margin-bottom: 6px;
        }

        .subtitulo {
            text-align: left;
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 16px;
        }

        ul {
            padding-left: 20px;
            margin-bottom: 25px;
            font-size: 15px;
        }

            ul li {
                margin-bottom: 8px;
            }

        .linea-separadora {
            height: 2px;
            background: linear-gradient(to right, #d236fe, #ffbd66);
            margin: 18px 0;
            border-radius: 2px;
        }

        .checkbox-group {
            display: flex;
            flex-direction: row;
            gap: 20px;
            margin: 10px 0;
            align-items: center;
            flex-wrap: wrap;
        }

            .checkbox-group label {
                display: flex;
                align-items: center;
                gap: 8px;
                cursor: pointer;
                white-space: nowrap;
            }

            .checkbox-group input[type="radio"] {
                margin: 0;
                cursor: pointer;
            }

        .metodopago {
            margin-top: 20px;
        }

            .metodopago .checkbox-group {
                margin-top: 10px;
            }

        .formbold-form-input {
            width: 50%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
        }

        .Escribir.nombre {
            margin-bottom: 15px;
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }

        .foto_alumno {
            max-width: 100%;
            height: auto;
            margin: 10px 0;
        }

        .status-indicador {
            font-weight: bold;
            padding: 5px 10px;
            border-radius: 5px;
            display: inline-block;
        }

        .status-activo {
            background-color: #d4edda;
            color: #155724;
        }

        .status-inactivo {
            background-color: #f8d7da;
            color: #721c24;
        }

        .info-alumno {
            margin: 15px 0;
            padding: 10px;
            background-color: #f8f9fa;
            border-radius: 5px;
        }

        .dato-row {
            margin-bottom: 5px;
        }

        .btn-guardar {
            background-color: #28a745;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 16px;
            margin-top: 15px;
            width: 100%;
        }

            .btn-guardar:hover {
                background-color: #218838;
            }

        .btn-extraer {
            background-color: #007bff;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 4px;
            cursor: pointer;
        }

            .btn-extraer:hover {
                background-color: #0056b3;
            }

        .mensaje-exito {
            background-color: #d4edda;
            color: #155724;
            padding: 10px;
            border-radius: 5px;
            margin-top: 15px;
            text-align: center;
            display: none;
        }
        /* Clase para deshabilitar visualmente la sección de servicio */
        .seccion-deshabilitada {
            opacity: 0.5;
            pointer-events: none;
        }

        .aviso-inactivo {
            background-color: #f8d7da;
            color: #721c24;
            padding: 10px;
            border-radius: 5px;
            margin-top: 10px;
            text-align: center;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <h2>Reinscripción</h2>
    <div class="contenedor">
        <!-- Tarjeta Alumno -->
        <div class="card blanco">
            <div class="titulo">Alumno</div>

            <div class="Escribir nombre">
                <input type="text" name="nombre" id="nombreInput" placeholder="Escribe Nombre" class="formbold-form-input" required />
                <input type="text" name="apellido" id="apellidoInput" placeholder="Escribe Apellido" class="formbold-form-input" required />
                <button type="button" onclick="buscarAlumno()" class="btn-extraer">Extraer</button>
            </div>

            <img src="/img/fondo.png" class="foto_alumno" alt="Foto del alumno">

            <div id="infoAlumno" class="info-alumno" style="display: none;"></div>

            <hr class="linea-separadora">
            @*
            <div class="formbold-input-group">
                <label class="label">Status</label>
                <div id="statusContainer">
                    <select class="formbold-form-input" id="statusSelect" onchange="cambiarStatus()">
                        <option value="Activo">Activo</option>
                        <option value="Inactivo">Inactivo</option>
                    </select>
                </div>
            </div>*@
        </div>

        <!-- Tarjeta Servicio -->
        <div class="card naranja" id="servicioCard">
            <div class="titulo">Servicio</div>

            <div id="servicioContent">
                <label>Tipo de Servicio</label>
                <div class="checkbox-group">
                    <label>
                        <input type="radio" name="tipoServicio" value="completo" id="servicioCompleto"> Completo
                    </label>
                    <label>
                        <input type="radio" name="tipoServicio" value="ordinal" id="servicioOrdinal"> Ordinal
                    </label>
                </div>

                <div class="metodopago">
                    <label>Método de pago</label>
                    <div class="checkbox-group">
                        <label>
                            <input type="radio" name="metodoPago" value="efectivo" id="pagoEfectivo"> Efectivo
                        </label>
                        <label>
                            <input type="radio" name="metodoPago" value="transferencia" id="pagoTransferencia"> Transferencia
                        </label>
                    </div>
                </div>
            </div>

            <!-- Aviso para status inactivo -->
            <div id="avisoInactivo" class="aviso-inactivo" style="display: none;">
                <i class="fas fa-exclamation-triangle"></i>
                Alumno inactivo - Solo se guardará el status
            </div>

            <button type="button" onclick="guardarReinscripcion()" class="btn-guardar" id="btnGuardar">Guardar Reinscripción</button>

            <!-- Mensaje de éxito -->
            <div id="mensajeExito" class="mensaje-exito">
                ✓ Reinscripción guardada exitosamente
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        var alumnoActual = null;

        function buscarAlumno() {
            var nombre = $('#nombreInput').val().trim();
            var apellido = $('#apellidoInput').val().trim();

            if (!nombre) {
                alert('Por favor ingresa el nombre del alumno');
                return;
            }

            $('#infoAlumno').html('<p style="color: blue;">Buscando...</p>').show();

            $.ajax({
                url: '@Url.Action("BuscarAlumno", "Reinscripcion")',
                type: 'GET',
                data: {
                    nombre: nombre,
                    apellido: apellido || ''
                },
                success: function(response) {
                    if (response.encontrado) {
                        alumnoActual = response.idAlumno;

                        var statusClass = response.status === 'Activo' ? 'status-activo' : 'status-inactivo';

                        var html = `
                            <div class="dato-row"><strong>Nombre:</strong> ${response.nombre} ${response.apellido}</div>
                            <div class="dato-row"><strong>Teléfono:</strong> ${response.telefono || 'No registrado'}</div>
                            <div class="dato-row"><strong>Correo:</strong> ${response.correo || 'No registrado'}</div>
                            <div class="dato-row">
                                <strong>Status:</strong>
                                <span class="status-indicador ${statusClass}">${response.status || 'Activo'}</span>
                            </div>
                        `;

                        $('#infoAlumno').html(html).show();
                        $('#statusSelect').val(response.status || 'Activo');

                        // Llamar a cambiarStatus para actualizar la UI según el status
                        cambiarStatus();

                    } else {
                        alumnoActual = null;
                        $('#infoAlumno').html('<p style="color: red;">Alumno no encontrado</p>').show();
                    }
                },
                error: function(xhr, status, error) {
                    alert('Error al buscar el alumno: ' + error);
                    $('#infoAlumno').hide();
                }
            });
        }
            
        function cambiarStatus() {
            var status = $('#statusSelect').val();

            if (status === 'Inactivo') {
                // Si es inactivo, deshabilitar la sección de servicio
                $('#servicioContent').addClass('seccion-deshabilitada');
                $('#avisoInactivo').show();

                // Deshabilitar los radios para que no se puedan seleccionar
                $('input[name="tipoServicio"]').prop('disabled', true);
                $('input[name="metodoPago"]').prop('disabled', true);
            } else {
                // Si es activo, habilitar la sección de servicio
                $('#servicioContent').removeClass('seccion-deshabilitada');
                $('#avisoInactivo').hide();

                // Habilitar los radios
                $('input[name="tipoServicio"]').prop('disabled', false);
                $('input[name="metodoPago"]').prop('disabled', false);
            }
        }

        function guardarReinscripcion() {
            if (!alumnoActual) {
                alert('Primero debe buscar un alumno');
                return;
            }

            var status = $('#statusSelect').val();
            var tipoServicio = '';
            var metodoPago = '';
            var lapso = '2025-1';

            // Si es activo, validar que haya seleccionado servicio y método de pago
            if (status === 'Activo') {
                tipoServicio = $('input[name="tipoServicio"]:checked').val();
                metodoPago = $('input[name="metodoPago"]:checked').val();

                if (!tipoServicio) {
                    alert('Seleccione un tipo de servicio');
                    return;
                }

                if (!metodoPago) {
                    alert('Seleccione un método de pago');
                    return;
                }
            } else {
                // Si es inactivo, no necesita servicio ni método de pago
                tipoServicio = '';
                metodoPago = '';
            }

            var datos = {
                IdAlumno: alumnoActual,
                Status: status,
                TipoServicio: tipoServicio,
                Lapso: lapso,
                MetodoPago: metodoPago
            };

            $.ajax({
                url: '@Url.Action("GuardarReinscripcion", "Reinscripcion")',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(datos),
                success: function(response) {
                    if (response.success) {
                        $('#mensajeExito').fadeIn().delay(3000).fadeOut();

                        // Limpiar los campos después de guardar
                        $('#nombreInput').val('');
                        $('#apellidoInput').val('');
                        $('#infoAlumno').hide();
                        $('input[name="tipoServicio"]').prop('checked', false);
                        $('input[name="metodoPago"]').prop('checked', false);
                        $('#statusSelect').val('Activo');
                        alumnoActual = null;

                        // Restaurar la UI
                        cambiarStatus();
                    } else {
                        alert('Error: ' + response.mensaje);
                    }
                },
                error: function() {
                    alert('Error al guardar la reinscripción');
                }
            });
        }
    </script>
</body>
</html>
@{
    ViewData["Title"] = "Privacy Policy";
}


<p></p>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Inter", sans-serif;
            background-color: #f3f4f6;
            color: #07074D;
        }

        .gym-navbar {
            background-color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 70px;
        }

        .nav-logo {
            font-size: 24px;
            font-weight: 700;
            color: #07074D;
            text-decoration: none;
            letter-spacing: 1px;
        }

            .nav-logo span {
                color: #6A64F1;
            }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 25px;
            align-items: center;
        }

        .nav-link {
            text-decoration: none;
            color: #536387;
            font-weight: 500;
            font-size: 16px;
            transition: color 0.3s ease;
            padding: 24px 0;
        }

            .nav-link:hover, .nav-link.active {
                color: #6A64F1;
            }

        .dropdown {
            position: relative;
            display: inline-block;
        }

            .dropdown > .nav-link::after {
                content: " ▼";
                font-size: 10px;
                vertical-align: middle;
                margin-left: 4px;
                opacity: 0.7;
            }

        .dropdown-menu {
            display: none;
            position: absolute;
            background-color: #ffffff;
            min-width: 220px;
            box-shadow: 0px 8px 20px rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            top: 40px;
            left: 0;
            list-style: none;
            padding: 10px 0;
            border: 2px solid #DDE3EC;
            z-index: 1001;
        }

        .dropdown:hover .dropdown-menu {
            display: block;
            animation: fadeIn 0.2s ease-in-out;
        }

        .dropdown-menu li a {
            color: #536387;
            padding: 12px 20px;
            text-decoration: none;
            display: block;
            font-size: 15px;
            font-weight: 500;
            transition: background-color 0.2s, color 0.2s;
        }

            .dropdown-menu li a:hover {
                background-color: #f8f9fa;
                color: #6A64F1;
                border-left: 3px solid #6A64F1;
                padding-left: 17px;
            }

       /* keyframes fadeIn {
            from;
        }

        {
            opacity: 0;
            transform: translateY(10px);
        }*/

        to {
            opacity: 1;
            transform: translateY(0);
        }

        .nav-btn-logout {
            background-color: #fee2e2;
            color: #991b1b;
            padding: 8px 20px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: background-color 0.3s ease;
        }

            .nav-btn-logout:hover {
                background-color: #fca5a5;
            }

        .dashboard-container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .dashboard-header {
            margin-bottom: 30px;
        }

            .dashboard-header h1 {
                font-size: 28px;
                font-weight: 700;
                margin-bottom: 8px;
            }

            .dashboard-header p {
                color: #536387;
                font-size: 16px;
            }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background-color: #ffffff;
            padding: 24px;
            border-radius: 8px;
            box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.05);
            border-left: 5px solid #6A64F1;
        }

            .stat-card h3 {
                font-size: 14px;
                color: #536387;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 10px;
            }

            .stat-card .number {
                font-size: 32px;
                font-weight: 700;
                color: #07074D;
            }

        .image-center-container {
            text-align: center;
            margin-bottom: 10px;
        }

        .responsive-image {
            max-width: 100%;
            height: auto;
        }
    </style>
</head>
<body>

    <nav class="gym-navbar">
        <div class="nav-container">
            <a href="/Home/Privacy" class="nav-logo">COLEGIO</a>

            <ul class="nav-menu">
                <li><a href="/Home/Privacy" class="nav-link active">Inicio</a></li>

                <li class="dropdown">
                    <a href="#" class="nav-link"> Alumnos</a>
                    <ul class="dropdown-menu">
                        <li><a href="/Alumnos/AlumnoA">Lista de alumnos</a></li>
                        <li><a href="/Alumnos/NuevoAlumno">Nuevo Alumno</a></li>
                    </ul>
                </li>

                <li class="dropdown">
                    <a href="#" class="nav-link">Servicio</a>
                    <ul class="dropdown-menu">
                        <li><a href="/Servicio/ServicioA">Tipo de Servicios</a></li>
                        <li><a href="/Servicio/CrearServicioA">Crear Servicio</a></li>

                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="nav-link">Reinscripción </a>
                    <ul class="dropdown-menu">
                        <li><a href="/Reinscripcion/ReinscripcionA">Reinscripcion</a></li>
                        <li><<a href="/Reinscripcion/Reinscripcion">Prueba</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="nav-link">Corte </a>
                    <ul class="dropdown-menu">
                        <li><a href="/Corte/corteA">Corte</a></li>
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="nav-link">Reporte </a>
                    <ul class="dropdown-menu">
                        <li><a href="/Reporte/ReporteA">Reporte</a></li>                       
                    </ul>
                </li>
                <li class="dropdown">
                    <a href="#" class="nav-link">Administradores</a>
                    <ul class="dropdown-menu">
                        <li><a href="/Home/SociosA">Lista de Usuarios</a></li>
                        <li><a href="/Usuarios/Nuevo">Nuevo Administrador</a></li>
                        <li><a href="/Reportes/Finanzas">Reportes Financieros</a></li>
                    </ul>
                </li>
            </ul>

            <div>
                <a href="/Acceso/Index" class="nav-btn-logout">Cerrar Sesión</a>
            </div>
        </div>
    </nav>
    
</body>
</html>

